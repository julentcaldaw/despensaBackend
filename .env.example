# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/despensa?schema=public

# JWT
JWT_SECRET=replace_with_secure_secret
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_another_secure_secret
JWT_REFRESH_EXPIRES_IN=7d

# Security
BCRYPT_SALT_ROUNDS=10

# Automation (n8n)
N8N_URL=http://localhost:5678/webhook-test/your-webhook-id
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=replace_with_n8n_api_key
N8N_TIMEOUT_MS=15000
N8N_USER=replace_with_n8n_basic_auth_user
N8N_PASSWORD=replace_with_n8n_basic_auth_password
